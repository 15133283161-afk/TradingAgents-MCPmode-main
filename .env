# 大模型配置
OPENAI_API_KEY=sk-28d9405fe7ac4890813649d2517ca058
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# LLM 配置（MCP管理器使用）
LLM_API_KEY=sk-28d9405fe7ac4890813649d2517ca058
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1

# 工作流配置
MAX_DEBATE_ROUNDS=1
MAX_RISK_DEBATE_ROUNDS=1
DEBUG_MODE=true
VERBOSE_LOGGING=true

# 智能体MCP权限配置
# 注意：环境变量名必须以 _MCP_ENABLED 结尾（不是 _MCP）
# 分析师团队 - 建议开启MCP以获取实时数据
COMPANY_OVERVIEW_ANALYST_MCP_ENABLED=true
MARKET_ANALYST_MCP_ENABLED=true
SENTIMENT_ANALYST_MCP_ENABLED=true
NEWS_ANALYST_MCP_ENABLED=true
FUNDAMENTALS_ANALYST_MCP_ENABLED=true
SHAREHOLDER_ANALYST_MCP_ENABLED=true
PRODUCT_ANALYST_MCP_ENABLED=true

# 研究员团队 - 可根据需要开启
BULL_RESEARCHER_MCP_ENABLED=true
BEAR_RESEARCHER_MCP_ENABLED=true

# 管理层 - 可根据需要开启
RESEARCH_MANAGER_MCP_ENABLED=true
TRADER_MCP_ENABLED=true

# 风险管理团队 - 可根据需要开启
AGGRESSIVE_RISK_ANALYST_MCP_ENABLED=true
SAFE_RISK_ANALYST_MCP_ENABLED=true
NEUTRAL_RISK_ANALYST_MCP_ENABLED=true
RISK_MANAGER_MCP_ENABLED=true

# 任务数量并发限制
MAX_CONCURRENT_ANALYSIS=3

# Tushare API Token
TUSHARE_TOKEN=bc8515a651ab1e6e04457824f0b8d2636c7fb49a7405502070d5ddf0
INVESTODAY_API_KEY=95407e5e027841688d792520395348c9